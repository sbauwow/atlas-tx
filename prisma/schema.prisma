// Citizen water-observation prototype — see docs/research/smartphone-colorimetry.md.
// Strictly non-regulatory; isolated from any DWRS / regulatory scoring surfaces.

generator client {
  provider = "prisma-client-js"
}

// Prisma 7: connection lives in prisma.config.ts via the adapter pattern.
datasource db {
  provider = "sqlite"
}

model WaterObservation {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  // Discriminator. v1 ships only "strip"; the column lets future kinds
  // ("tds", "tap-photo", "plumbing-form") land without a migration.
  kind          String

  countySlug    String?
  imagePath     String?
  imageHash     String?  @unique

  stripBrand    String?

  // JSON-as-text — SQLite has no native JSON/array column.
  // Schemas defined in src/lib/observations/types.ts.
  clientReading String
  llmReading    String?
  llmModel      String?

  agreement     Float?
  qaFlags       String?

  status        String   @default("pending")
  caveatsShown  Boolean  @default(false)

  @@index([createdAt])
  @@index([kind])
  @@index([countySlug])
}

model WatchlistWorkspace {
  id        String      @id @default(cuid())
  slug      String      @unique
  label     String
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  watchlists Watchlist[]
}

model Watchlist {
  id          String             @id @default(cuid())
  workspaceId String
  label       String
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  workspace   WatchlistWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items       WatchlistItem[]

  @@index([workspaceId])
  @@index([createdAt])
}

model WatchlistItem {
  id           String    @id @default(cuid())
  watchlistId  String
  itemType     String
  itemKey      String
  displayLabel String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  watchlist    Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, itemType, itemKey])
  @@index([watchlistId])
  @@index([itemType, itemKey])
}

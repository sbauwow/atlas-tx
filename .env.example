# Atlas TX — environment example
# Copy to .env.local and fill in. Never commit .env.local.

# Citizen-observation prototype (Prisma + SQLite)
DATABASE_URL="file:./prisma/dev.db"

# OpenAI vision sanity-check for citizen strip submissions (optional in dev —
# server falls back to client-only reading if unset). Used by
# src/lib/observations/vision.ts → gpt-4o-mini chat.completions with tool_choice.
OPENAI_API_KEY=

# Atlas TX — environment example
# Copy to .env.local and fill in. Never commit .env.local.

# Citizen-observation prototype (Prisma + SQLite)
DATABASE_URL="file:./prisma/dev.db"

# Vision sanity-check for citizen strip submissions (optional in dev — server
# falls back to client-only reading when both keys are empty). The android
# capture app uploads to /api/citizen/observations; the route calls a vision
# model server-side. Featherless takes precedence when its key is set.
#
# Featherless (preferred): OpenAI-compatible chat.completions against a
# vision-language model on https://api.featherless.ai/v1, using
# response_format=json_object. Default model: meta-llama/Llama-4-Scout-17B-16E-Instruct.
# Override with FEATHERLESS_MODEL (e.g. Qwen/Qwen2.5-VL-72B-Instruct).
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=

# OpenAI fallback: gpt-4o-mini with tool_choice. Used only when
# FEATHERLESS_API_KEY is empty.
OPENAI_API_KEY=
